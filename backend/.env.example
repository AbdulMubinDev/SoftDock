SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,softdock.kybernode.com

# postgresql:// and postgres:// are both supported
DATABASE_URL=postgresql://softdock_user:password@localhost:5432/softdock_db
REDIS_URL=redis://localhost:6379/0

# Required for BYOK (user API keys). Required when DEBUG=False.
ENCRYPTION_KEY=

# Social login (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Billing (optional — not wired in MVP)
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Frontend origin(s) for CORS, OAuth redirects, CSRF (no trailing path)
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated if you have multiple origins (e.g. www + apex)
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

BACKEND_URL=http://localhost:8000

# Production only (DEBUG=False): set SECURE_SSL_REDIRECT=false if TLS is handled only by nginx and you need HTTP internally
# SECURE_SSL_REDIRECT=true
