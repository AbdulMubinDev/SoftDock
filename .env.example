# Copy to `.env` in this directory before first run:
#   cp .env.example .env
# Generate secrets:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

SECRET_KEY=change-me-generate-a-real-secret-key
ENCRYPTION_KEY=change-me-generate-a-fernet-key
DEBUG=False
SECURE_SSL_REDIRECT=false

POSTGRES_USER=softdock
POSTGRES_PASSWORD=softdock
POSTGRES_DB=softdock

WEB_PORT=8080

# Optional OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
